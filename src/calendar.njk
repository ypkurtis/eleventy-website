<!-- ── CALENDAR EMBED ────────────────────────────────────────────────────── -->
<section>
  <div class="container">

    <!--
      ══════════════════════════════════════════════════════════════
      HOW TO EMBED YOUR GOOGLE CALENDAR:

      1. Open Google Calendar (calendar.google.com)
      2. Click the ⚙️ settings gear → "Settings"
      3. Under "Settings for my calendars", click your church calendar
      4. Scroll to "Integrate calendar"
      5. Copy the "Embed code" (an <iframe> tag)
      6. Replace the entire <div class="calendar-placeholder"> block
         below with that <iframe> wrapped in <div class="calendar-embed">

      Example of what to paste:
        <div class="calendar-embed">
          <iframe src="https://calendar.google.com/calendar/embed?src=YOUR_ID%40group.calendar.google.com&ctz=America%2FIndiana%2FIndianapolis"
            style="border:0" width="800" height="650" frameborder="0" scrolling="no"></iframe>
        </div>

      TIP: Set the height on the iframe to "650" for a comfortable view,
      and add &mode=MONTH to the URL to default to month view.
      ══════════════════════════════════════════════════════════════
    -->

    <div class="calendar-placeholder">
      <span class="cal-icon">📅</span>
      <h3>Calendar Coming Soon</h3>
      <p>
        A Google Calendar embed will appear here. To set it up, open
        <code>src/calendar.njk</code> and follow the instructions in the
        comment above.
      </p>
    </div>

  </div>
</section>

