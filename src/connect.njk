---
layout: layouts/base.njk
title: Connect
description: "Get in touch with Summitville Wesleyan Bible Church. We would love to hear from you."
---

<!-- ── PAGE HERO ───────────────────────────────────────────────────────── -->
<section class="page-hero">
  <div class="container">
    <h1>Connect with Us</h1>
    <p>We would love to hear from you. Reach out anytime.</p>
  </div>
</section>

<!-- ── CONNECT SECTION ───────────────────────────────────────────────────── -->
<section>
  <div class="container">
    <div class="connect-grid">

      <!-- Contact Info -->
      <div class="connect-info">
        <h2>Get in Touch</h2>
        <p>
          Have a question about a service, ministry, or anything else? We are
          here to help. Fill out the form or reach us directly using the
          information below.
        </p>

        <div style="margin-top:2rem; display:grid; gap:1.25rem;">
          <div class="contact-detail">
            <span class="detail-icon">📍</span>
            <p>
              <strong>Address</strong><br>
              {{ site.address.full }}<br>
              <a href="{{ site.address.mapsUrl }}" target="_blank" rel="noopener noreferrer">Get Directions</a>
            </p>
          </div>

          <div class="contact-detail">
            <span class="detail-icon">📞</span>
            <p>
              <strong>Phone</strong><br>
              <a href="tel:{{ site.phone }}">{{ site.phone }}</a>
            </p>
          </div>

          <div class="contact-detail">
            <span class="detail-icon">✉️</span>
            <p>
              <strong>Email</strong><br>
              <a href="mailto:{{ site.email }}">{{ site.email }}</a>
            </p>
          </div>

          <div class="contact-detail">
            <span class="detail-icon">🕐</span>
            <p>
              <strong>Service Times</strong><br>
              {% for st in site.serviceTimes %}
              {{ st.name }}: {{ st.time }}<br>
              {% endfor %}
              <a href="/visit/">More visit info &rarr;</a>
            </p>
          </div>
        </div>

        <!-- Social -->
        <div style="margin-top:2rem;">
          <h3 style="font-size:1rem; text-transform:uppercase; letter-spacing:.06em; color:var(--text-muted); font-family:'Lato',sans-serif; margin-bottom:.75rem;">
            Follow Us
          </h3>
          <div class="social-links-row">
            <a
              href="{{ site.facebook }}"
              class="social-btn facebook"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
              </svg>
              Facebook
            </a>
          </div>
        </div>
      </div>

      <!-- Contact Form -->
      <div>
        <div class="form-wrapper" style="box-shadow:none; padding:0;">
          <!--
            FORM SETUP:
            - Netlify Forms: add data-netlify="true" (already included).
            - Formspree: replace action="#" with your Formspree URL.
            - Other backend: update action/method accordingly.
          -->
          <form
            name="contact"
            action="#"
            method="POST"
            data-netlify="true"
            netlify-honeypot="bot-field"
          >
            <p style="display:none;">
              <label>Don't fill this out: <input name="bot-field" /></label>
            </p>
            <input type="hidden" name="form-name" value="contact" />

            <div class="form-group">
              <label for="contact-subject">How Can We Help?</label>
              <select id="contact-subject" name="subject">
                <option value="">I'd like to ask about...</option>
                <option value="general">General Question</option>
                <option value="visit">Planning a Visit</option>
                <option value="ministries">Ministries</option>
                <option value="prayer">Prayer Request</option>
                <option value="giving">Giving</option>
                <option value="facilities">Facilities / Events</option>
                <option value="other">Other</option>
              </select>
            </div>

            <div class="form-row">
              <div class="form-group">
                <label for="contact-first">First Name <span aria-hidden="true">*</span></label>
                <input
                  type="text"
                  id="contact-first"
                  name="first-name"
                  required
                  autocomplete="given-name"
                  placeholder="First name"
                />
              </div>
              <div class="form-group">
                <label for="contact-last">Last Name <span aria-hidden="true">*</span></label>
                <input
                  type="text"
                  id="contact-last"
                  name="last-name"
                  required
                  autocomplete="family-name"
                  placeholder="Last name"
                />
              </div>
            </div>

            <div class="form-group">
              <label for="contact-email">Email Address <span aria-hidden="true">*</span></label>
              <input
                type="email"
                id="contact-email"
                name="email"
                required
                autocomplete="email"
                placeholder="your@email.com"
              />
            </div>

            <div class="form-group">
              <label for="contact-message">Message <span aria-hidden="true">*</span></label>
              <textarea
                id="contact-message"
                name="message"
                required
                placeholder="How can we help you?"
              ></textarea>
            </div>

            <button type="submit" class="btn btn-navy" style="width:100%; justify-content:center; font-size:1.05rem; padding:.9rem;">
              Send Message
            </button>

            <p class="form-note">
              We typically respond within 1–2 business days. For urgent pastoral
              care, please call us directly.
            </p>
          </form>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- ── NEW HERE CTA ───────────────────────────────────────────────────────── -->
<section class="service-band">
  <div class="container text-center">
    <h2 style="color:var(--gold); margin-bottom:1rem;">Thinking About Visiting?</h2>
    <p style="color:rgba(255,255,255,.75); max-width:500px; margin-inline:auto; margin-bottom:2rem;">
      We would love to see you in person. Check out our Visit page to learn
      what to expect on your first Sunday.
    </p>
    <a href="/visit/" class="btn btn-gold">Plan Your Visit</a>
  </div>
</section>
