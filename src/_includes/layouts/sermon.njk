---
layout: layouts/base.njk
---

<section class="page-hero">
  <div class="container">
    <p class="mb-2" style="color:var(--gold); font-size:.85rem; font-weight:700; text-transform:uppercase; letter-spacing:.08em;">
      {{ series }}
    </p>
    <h1>{{ title }}</h1>
    <p>{{ speaker }} &nbsp;·&nbsp; {{ page.date | dateFormat }}</p>
  </div>
</section>

<section>
  <div class="container" style="max-width:860px;">
    {% if youtubeId %}
    <div class="sermon-video-wrap" style="border-radius:var(--radius-lg); overflow:hidden; margin-bottom:2.5rem;">
      <iframe
        src="https://www.youtube-nocookie.com/embed/{{ youtubeId }}"
        title="{{ title }}"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
      ></iframe>
    </div>
    {% endif %}

    {% if scripture %}
    <div class="scripture-banner" style="margin-bottom:2rem;">
      <p style="font-size:.8rem; font-weight:700; text-transform:uppercase; letter-spacing:.08em; color:var(--gold); margin-bottom:.25rem;">Scripture</p>
      <p style="color:var(--navy); font-weight:700; margin:0;">{{ scripture }}</p>
    </div>
    {% endif %}

    {% if description %}
    <p style="font-size:1.05rem; color:var(--text-muted);">{{ description }}</p>
    {% endif %}

    {{ content | safe }}

    <div style="margin-top:3rem; padding-top:2rem; border-top:1px solid var(--border);">
      <a href="/messages/" class="btn btn-outline-navy">&larr; Back to All Messages</a>
    </div>
  </div>
</section>
