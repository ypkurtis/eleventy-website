<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="{{ description or site.description }}" />
    <title>
      {% if title %}{{ title }} | {{ site.name }}{% else %}{{ site.name }}{% endif %}
    </title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Lato:wght@300;400;700;900&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap"
      rel="stylesheet"
    />

    <!-- Stylesheet -->
    <link rel="stylesheet" href="/assets/css/main.css" />
  </head>

  <body>
    <!-- ── HEADER ─────────────────────────────────────────────────────────── -->
    <header class="site-header">
      <div class="container header-inner">
        <a href="/" class="site-logo" aria-label="{{ site.name }} — Home">
          <img
            src="/images/swbclogo.png"
            alt="{{ site.name }}"
            height="60"
            width="auto"
          />
        </a>

        <button
          class="nav-toggle"
          id="navToggle"
          aria-label="Open navigation menu"
          aria-expanded="false"
          aria-controls="siteNav"
        >
          <span></span>
          <span></span>
          <span></span>
        </button>

        <nav class="site-nav" id="siteNav" aria-label="Main navigation">
          <ul>
            <li>
              <a href="/" class="{{ page.url | activeIf('/') }}">Home</a>
            </li>
            <li>
              <a href="/im-new/" class="{{ page.url | activeIf('/im-new/') }}">I'm New</a>
            </li>
            <li class="has-dropdown">
              <a href="/ministries/" class="{{ page.url | activeIf('/ministries/') }}{{ page.url | activeIf('/ministries/childrens/') }}{{ page.url | activeIf('/ministries/youth/') }}{{ page.url | activeIf('/ministries/adults/') }}">Ministries <span class="dropdown-caret" aria-hidden="true">▾</span></a>
              <ul class="dropdown" role="list">
                <li><a href="/ministries/childrens/" class="{{ page.url | activeIf('/ministries/childrens/') }}">Children's Ministry</a></li>
                <li><a href="/ministries/youth/" class="{{ page.url | activeIf('/ministries/youth/') }}">Youth Group</a></li>
                <li><a href="/ministries/adults/" class="{{ page.url | activeIf('/ministries/adults/') }}">Adult Ministries</a></li>
              </ul>
            </li>
            <li class="has-dropdown">
              <a href="/about/" class="{{ page.url | activeIf('/about/') }}{{ page.url | activeIf('/about/leadership/') }}{{ page.url | activeIf('/about/beliefs/') }}{{ page.url | activeIf('/about/history/') }}">About Us <span class="dropdown-caret" aria-hidden="true">▾</span></a>
              <ul class="dropdown" role="list">
                <li><a href="/about/leadership/" class="{{ page.url | activeIf('/about/leadership/') }}">Our Leadership</a></li>
                <li><a href="/about/beliefs/" class="{{ page.url | activeIf('/about/beliefs/') }}">What We Believe</a></li>
                <li><a href="/about/history/" class="{{ page.url | activeIf('/about/history/') }}">Our History</a></li>
              </ul>
            </li>
            <li>
              <a href="/connect/" class="{{ page.url | activeIf('/connect/') }}">Connect</a>
            </li>
            <li>
              <a href="/messages/" class="{{ page.url | activeIf('/messages/') }}{{ page.url | activeIf('/sermons/') }}">Messages</a>
            </li>
            <li>
              <a href="/give/" class="{{ page.url | activeIf('/give/') }}">Give</a>
            </li>
          </ul>
        </nav>
      </div>
    </header>

    <!-- ── MAIN CONTENT ───────────────────────────────────────────────────── -->
    <main id="main-content">
      {{ content | safe }}
    </main>

    <!-- ── FOOTER ─────────────────────────────────────────────────────────── -->
    <footer class="site-footer">
      <div class="container">
        <div class="footer-grid">

          <!-- Brand column -->
          <div class="footer-col footer-brand">
            <a href="/" aria-label="{{ site.name }} — Home">
              <img
                src="/images/swbclogo%20black.png"
                alt="{{ site.name }}"
                height="50"
                width="auto"
                class="footer-logo-img"
              />
            </a>
            <p class="footer-tagline">
              A place of grace, community, and holiness in Summitville, Indiana.
            </p>
            <a
              href="{{ site.facebook }}"
              class="social-btn facebook"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Find us on Facebook"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
              </svg>
              Facebook
            </a>
          </div>

          <!-- Quick links -->
          <div class="footer-col">
            <h4>Quick Links</h4>
            <ul>
              <li><a href="/">Home</a></li>
              <li><a href="/about/">About Us</a></li>
              <li><a href="/visit/">Plan a Visit</a></li>
              <li><a href="/ministries/">Ministries</a></li>
              <li><a href="/video-archive/">Sermons</a></li>
              <li><a href="/calendar/">Calendar</a></li>
            </ul>
          </div>

          <!-- More links -->
          <div class="footer-col">
            <h4>Get Involved</h4>
            <ul>
              <li><a href="/team/">Meet Our Team</a></li>
              <li><a href="/give/">Give Online</a></li>
              <li><a href="/prayer/">Prayer Request</a></li>
              <li><a href="/connect/">Contact Us</a></li>
            </ul>
          </div>

          <!-- Contact info -->
          <div class="footer-col">
            <h4>Contact</h4>
            <address class="footer-address">
              <p>{{ site.address.full }}</p>
              <p><a href="tel:{{ site.phone }}">{{ site.phone }}</a></p>
              <p><a href="mailto:{{ site.email }}">{{ site.email }}</a></p>
            </address>
            <div class="footer-times">
              <strong>Service Times</strong>
              {% for st in site.serviceTimes %}
                <p>{{ st.name }}: {{ st.time }}</p>
              {% endfor %}
            </div>
          </div>

        </div>

        <div class="footer-bottom">
          <p>&copy; {{ site.currentYear }} {{ site.name }}. All rights reserved.</p>
          <p>Built with <span aria-label="love">&#9829;</span> for the Summitville community.</p>
        </div>
      </div>
    </footer>

    <script src="/assets/js/nav.js"></script>
  </body>
</html>
